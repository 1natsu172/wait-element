			"import": "./dist/detectors.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"typings": "./dist/index.d.ts",
	"dependencies": {
		"defu": "^6.1.4",
		"many-keys-map": "^3.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
