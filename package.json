	"version": "4.2.0",
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"author": "1natsu",
	"contributors": [
		"1natsu"
	],
	"bugs": {
		"url": "https://github.com/1natsu172/wait-element/issues",
		"email": "1natsu172@users.noreply.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/1natsu172/wait-element"
	},
	"homepage": "https://github.com/1natsu172/wait-element",
	"keywords": [
		"DOM",
		"MutationObserver",
		"Promise",
		"element",
		"selector",
		"querySelector",
		"detect",
		"wait",
		"await",
		"check",
		"exist",
		"appearance"
	],
